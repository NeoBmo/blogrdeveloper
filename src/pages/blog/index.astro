---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import ScrollSmootherInit from "../../components/ScrollSmootherInit.astro";
import { SiteTitle, SiteDescription } from "../../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";
import { getBlogUrl, sortPostsByDateDesc } from "../../utils/blog";

const posts = sortPostsByDateDesc(await getCollection("blog"));
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={SiteTitle} description={SiteDescription} />
  </head>
  <body>
    <Header />
    <main class="mt-20 w-full px-4 md:px-6 lg:px-8">
      <section class="max-w-7xl mx-auto">
        <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 list-none m-0 p-0">
          {
            posts.map((post) => (
              <li class="group rounded-xl from-neutral-900 to-neutral-800 overflow-hidden hover:shadow-xl hover:shadow-pink-500/20 transition-all duration-500 transform hover:-translate-y-1 border border-neutral-700 hover:border-pink-400/50">
                <a
                  href={getBlogUrl(post)}
                  class="block h-full p-6 no-underline transition-all duration-300"
                >
                  <h4 class="m-0 text-lg md:text-xl font-semibold text-neutral-100 group-hover:text-pink-400 transition-colors duration-300 line-clamp-2">
                    {post.data.title}
                  </h4>
                  <p class="m-0 text-sm md:text-base text-neutral-400 group-hover:text-neutral-300 transition-colors duration-300 mt-3">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <ScrollSmootherInit />
  </body>
</html>
